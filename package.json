{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.cjs --format=cjs --external:vite --external:@prisma/client --external:express --external:helmet --external:compression --external:morgan --external:dotenv --external:bcryptjs --external:jsonwebtoken --external:path --external:url",
    "start": "NODE_ENV=production node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@prisma/client": "^6.4.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "morgan": "^1.10.1",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "react-virtuoso": "^4.18.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "prisma": "^6.4.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
